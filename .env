# Dev defaults for `docker compose up`. Auto-loaded by Compose and injected into
# the snapreq container via env_file. Non-secret — safe to commit.
# Put personal/secret overrides in .env.local (gitignored).

# EchoChamber on the shared reexec-net (its service name is "app").
ECHOCHAMBER_URL=http://app:8080
# Optional ingest auth. Empty by default in dev => no Authorization header
# (EchoChamber's INTERNAL_INGEST_TOKEN must also be empty). To enable auth, set a
# value here AND the same value as EchoChamber's INTERNAL_INGEST_TOKEN.
ECHOCHAMBER_TOKEN=

LISTEN_ADDR=:8080
# Uncomment to run Mode A (in-path proxy) instead of mirror mode:
# FORWARD_URL=http://upstream:9000
FORWARD_TIMEOUT_MS=5000
CAPTURE_TIMEOUT_MS=2000
MAX_BODY_BYTES=1048576
LOG_LEVEL=info
CAPTURE_AUTH_HEADERS=false
