# SnapReq configuration (see Agent.md §4). Copy to .env for local use.

# Required
ECHOCHAMBER_URL=http://echochamber:8080
# Optional: leave empty to send ingest without auth (EchoChamber must match)
ECHOCHAMBER_TOKEN=dev-ingest-token

# Optional
LISTEN_ADDR=:8080
# FORWARD_URL=http://upstream:9000   # set => Mode A (in-path proxy); unset => Mode B/D (mirror)
FORWARD_TIMEOUT_MS=5000
CAPTURE_TIMEOUT_MS=2000
MAX_BODY_BYTES=1048576
LOG_LEVEL=info
CAPTURE_AUTH_HEADERS=false
